NODE_ENV=production
PORT=4001

# PostgreSQL — individual connection fields
DB_HOST=
DB_PORT=5432
DB_NAME=securitypass
DB_USER=                  # dedicated DB user, not postgres superuser
DB_PASSWORD=              # use a strong random password, min 24 chars
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=               # minimum 64 chars in production — NEVER commit the real value
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt — higher rounds = more secure but slower login (12 recommended for prod)
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# CORS — comma-separated allowed origins, NO wildcards in production
CORS_ORIGIN=https://yourdomain.com

# Logging
LOG_LEVEL=warn
LOG_DIR=./logs
