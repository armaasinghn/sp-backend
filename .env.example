# ─── SERVER ────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── DATABASE ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=securitypass
DB_USER=sp_user
DB_PASSWORD=sp_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ─── BCRYPT ────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── RATE LIMITING ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── FILE UPLOADS ──────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── LOGGING ───────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
