{
  "name": "securitypass-backend",
  "version": "1.0.0",
  "description": "Security Pass Access Management System — Node.js/Express API with PostgreSQL",
  "main": "src/backend/server.js",
  "scripts": {
    "start": "node src/backend/server.js",
    "start:prod": "NODE_ENV=production node src/backend/server.js",
    "dev": "nodemon src/backend/server.js",
    "db:migrate": "node migrations/run.js",
    "db:seed": "node seeds/run.js",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "test": "jest --detectOpenHandles"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
